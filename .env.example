# ===========================================================================
#  Provider selection
#  Choose which backend powers the editing. If unset, slikaAI auto-detects:
#    FAL_KEY present      -> fal
#    COMFYUI_URL present  -> comfyui
#    otherwise            -> mock (free, no key)
#  Force one explicitly with PROVIDER = mock | fal | comfyui
# ===========================================================================
PROVIDER=

# --- Free dev mode (no key, no GPU) ---
# Echoes the uploaded image back so you can build/test the whole UI flow.
# Set to 1 to force mock mode even when a provider is configured.
MOCK_EDIT=

# --- fal.ai (hosted FLUX Kontext) ---
# Get yours at https://fal.ai/dashboard/keys
FAL_KEY=
FAL_EDIT_MODEL=fal-ai/flux-pro/kontext
FAL_INPAINT_MODEL=fal-ai/flux-pro/v1/fill

# --- ComfyUI (local FLUX Kontext dev — free, runs on your machine) ---
# Start ComfyUI, then point slikaAI at it.
# The ComfyUI *desktop app* listens on :8000; the classic install uses :8188.
COMFYUI_URL=http://127.0.0.1:8000
# Max time to wait for a result (ms). Apple Silicon edits take minutes.
COMFYUI_TIMEOUT_MS=600000
# Workflow templates (API format) with __PROMPT__ / __IMAGE__ / __MASK__ / __SEED__ placeholders.
# Paths are relative to the project root. NOTE: on Apple Silicon use GGUF/bf16, NOT fp8.
COMFYUI_EDIT_WORKFLOW=comfyui/flux-kontext-edit.json
COMFYUI_INPAINT_WORKFLOW=comfyui/flux-kontext-inpaint.json
