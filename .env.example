# fal.ai credentials — get yours at https://fal.ai/dashboard/keys
FAL_KEY=your_fal_api_key_here

# Optional: override the models used (defaults shown).
# Whole-image, instruction-based editing (no mask):
FAL_EDIT_MODEL=fal-ai/flux-pro/kontext
# Brush / mask inpainting (white = area to change):
FAL_INPAINT_MODEL=fal-ai/flux-pro/v1/fill
