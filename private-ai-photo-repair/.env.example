# Real ONNX model URLs (optional).
#
# Leave any value blank to keep that task in MOCK MODE. When a URL is provided,
# the app will download and cache that model and attempt real ONNX inference.
#
# Models are downloaded ONCE, stored locally on the device (IndexedDB), reused
# afterwards, and can be deleted at any time from the Model Manager.

VITE_BACKGROUND_REMOVAL_MODEL_URL=
VITE_DENOISE_MODEL_URL=
VITE_ENHANCE_MODEL_URL=
VITE_SUPER_RESOLUTION_MODEL_URL=
VITE_RESTORE_OLD_PHOTO_MODEL_URL=
VITE_REFERENCE_GUIDED_RESTORE_MODEL_URL=

# ---------------------------------------------------------------------------
# Hybrid generative editing ("describe any edit")
# ---------------------------------------------------------------------------
# A real generative edit needs a diffusion-class model, which is too big to run
# well in a phone browser. This task is therefore HYBRID:
#
#   - LOCAL  (on-device, fully private): set a URL to an ONNX generative model.
#            Only runs on WebGPU-capable machines. Leave blank to keep the
#            on-device path as a clearly-labelled simulation.
VITE_GENERATIVE_EDIT_MODEL_URL=
#
#   - CLOUD  (opt-in, leaves the device): the image is uploaded to this editing
#            endpoint. The default contract matches this repo's Next.js
#            /api/edit route (FLUX Kontext via fal / ComfyUI). Works on any
#            device, but the user must explicitly consent in the UI first.
#            Leave blank to disable the cloud engine entirely.
VITE_CLOUD_EDIT_ENDPOINT=

# Master switch for mock pipelines. Keep "true" so the app still works when no
# real model URLs are configured.
VITE_ENABLE_MOCK_MODE=true
