{
  "_comment": "slikaAI whole-image edit workflow — FLUX.1 Kontext [dev] GGUF (Apple Silicon / MPS friendly), ComfyUI API format. Requires the ComfyUI-GGUF custom node. Placeholders __PROMPT__, __IMAGE__ and __SEED__ are filled in at request time. Adjust model filenames in nodes 37/38/39 to match your install. NOTE: fp8 weights do NOT run on Apple Silicon (MPS) — use GGUF or bf16.",
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "__PROMPT__", "clip": ["38", 0] }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["31", 0], "vae": ["39", 0] }
  },
  "31": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": 1,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1,
      "model": ["37", 0],
      "positive": ["35", 0],
      "negative": ["42", 0],
      "latent_image": ["41", 0]
    }
  },
  "35": {
    "class_type": "FluxGuidance",
    "inputs": { "guidance": 2.5, "conditioning": ["177", 0] }
  },
  "37": {
    "class_type": "UnetLoaderGGUF",
    "inputs": {
      "unet_name": "flux1-kontext-dev-Q4_K_M.gguf"
    }
  },
  "38": {
    "class_type": "DualCLIPLoaderGGUF",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5-v1_1-xxl-encoder-Q5_K_M.gguf",
      "type": "flux"
    }
  },
  "39": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "ae.safetensors" }
  },
  "41": {
    "class_type": "VAEEncode",
    "inputs": { "pixels": ["42_scale", 0], "vae": ["39", 0] }
  },
  "42": {
    "class_type": "ConditioningZeroOut",
    "inputs": { "conditioning": ["6", 0] }
  },
  "42_scale": {
    "class_type": "ImageScaleToTotalPixels",
    "inputs": { "image": ["142", 0], "upscale_method": "lanczos", "megapixels": "__MP__", "resolution_steps": 1 }
  },
  "142": {
    "class_type": "LoadImage",
    "inputs": { "image": "__IMAGE__", "upload": "image" }
  },
  "177": {
    "class_type": "ReferenceLatent",
    "inputs": { "conditioning": ["6", 0], "latent": ["41", 0] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "slikaAI", "images": ["8", 0] }
  }
}
